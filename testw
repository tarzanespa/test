local function switchTab(tab)
    if ActiveTab == tab then return end
    for _, t in ipairs(Tabs) do
        t.frame.Visible = false
        tween(t.button, {BackgroundTransparency=1, TextColor3=CONFIG.MutedColor}, 0.15)
    end
    ActiveTab = tab
    tab.frame.Visible = true
    tween(tab.button, {BackgroundTransparency=0.85, TextColor3=CONFIG.TextColor}, 0.15)
end

local function addTab(name)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1,0,0,34)
    btn.BackgroundColor3 = CONFIG.AccentColor
    btn.BackgroundTransparency = 1
    btn.Text = name
    btn.TextSize = 12
    btn.Font = Enum.Font.GothamSemibold
    btn.TextColor3 = CONFIG.MutedColor
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.ZIndex = 12
    btn.Parent = Sidebar
    corner(btn, 6)

    local bp = Instance.new("UIPadding")
    bp.PaddingLeft = UDim.new(0,10)
    bp.Parent = btn

    local frame = Instance.new("ScrollingFrame")
    frame.Size = UDim2.new(1,0,1,0)
    frame.BackgroundTransparency = 1
    frame.BorderSizePixel = 0
    frame.ZIndex = 12
    frame.Visible = false
    frame.ScrollBarThickness = 3
    frame.ScrollBarImageColor3 = CONFIG.AccentColor
    frame.CanvasSize = UDim2.new(0,0,0,0)
    frame.AutomaticCanvasSize = Enum.AutomaticSize.Y
    frame.Parent = ContentArea

    local layout = Instance.new("UIListLayout")
    layout.Padding = UDim.new(0,6)
    layout.Parent = frame

    local pad = Instance.new("UIPadding")
    pad.PaddingTop    = UDim.new(0,10)
    pad.PaddingLeft   = UDim.new(0,10)
    pad.PaddingRight  = UDim.new(0,10)
    pad.PaddingBottom = UDim.new(0,10)
    pad.Parent = frame

    local tabData = {name=name, button=btn, frame=frame}
    table.insert(Tabs, tabData)
    btn.MouseButton1Click:Connect(function() switchTab(tabData) end)
    if #Tabs == 1 then switchTab(tabData) end
    return tabData
end

