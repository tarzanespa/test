addToggle(tabVis, "ESP NPCs (nomes)", false, function(on)
    for _, c in ipairs(espConns) do c:Disconnect() end
    espConns = {}

    if on then
        local function applyESP(model)
            if not model:IsA("Model") then return end
            if not model:FindFirstChildOfClass("Humanoid") then return end
            if isPlayerCharacter(model) then return end
            local hrp = model:FindFirstChild("HumanoidRootPart")
            if not hrp or hrp:FindFirstChild("ESP_Tag") then return end

            local hum = model:FindFirstChildOfClass("Humanoid")
            local isBoss = hum and hum.MaxHealth >= 500

            local bb = Instance.new("BillboardGui")
            bb.Name = "ESP_Tag"
            bb.Size = UDim2.new(0,120,0,34)
            bb.StudsOffset = Vector3.new(0,3,0)
            bb.AlwaysOnTop = true
            bb.Parent = hrp

            local tl = Instance.new("TextLabel")
            tl.Size = UDim2.new(1,0,1,0)
            tl.BackgroundTransparency = 1
            tl.Text = (isBoss and "👑 BOSS  " or "⚠ ") .. model.Name
            tl.TextSize = isBoss and 14 or 12
            tl.Font = Enum.Font.GothamBold
            tl.TextColor3 = isBoss and Color3.fromRGB(255,200,0) or Color3.fromRGB(255,80,80)
            tl.TextStrokeTransparency = 0
            tl.Parent = bb
        end

        for _, obj in ipairs(workspace:GetDescendants()) do applyESP(obj) end
        local c = workspace.DescendantAdded:Connect(function(d) task.wait() applyESP(d) end)
        table.insert(espConns, c)
        notify("ESP", "Ativo — Bosses em amarelo, NPCs em vermelho")
    else
        for _, obj in ipairs(workspace:GetDescendants()) do
            local tag = obj:FindFirstChild("ESP_Tag")
            if tag then tag:Destroy() end
        end
        notify("ESP", "Desativado")
    end
end)

