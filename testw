--  INVISIBILIDADE
--  Torna as partes do personagem transparentes
-- ══════════════════════════════════════════
local invisActive = false
local originalTransparency = {}

local function applyInvis(on)
    local char = getChar()
    if not char then return end
    for _, p in ipairs(char:GetDescendants()) do
        if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" then
            if on then
                originalTransparency[p] = p.Transparency
                p.Transparency = 1
            else
                p.Transparency = originalTransparency[p] or p.Transparency
            end
        end
        if p:IsA("Decal") then
            if on then
                originalTransparency[p] = p.Transparency
                p.Transparency = 1
            else
                p.Transparency = originalTransparency[p] or 0
            end
        end
    end
end

