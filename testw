local function getChar() return LocalPlayer.Character end
local function getHum()  return getChar() and getChar():FindFirstChildOfClass("Humanoid") end
local function getHRP()  return getChar() and getChar():FindFirstChild("HumanoidRootPart") end

local function isPlayer(model)
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character == model then return true end
    end
    return false
end

-- ══════════════════════════════════════════
--  INSTAKILL — CORRIGIDO (Server-sided aware)
--  Tenta múltiplos métodos:
--    1) Humanoid direto (funciona em jogos com física client-side)
--    2) TakeDamage
--    3) FireServer via RemoteEvents de dano do jogo
--    4) Procura remotes em ReplicatedStorage e workspace
-- ══════════════════════════════════════════
local ikRange  = 15
local ikActive = false

local function tryRemotes(obj, model, hum)
    for _, v in ipairs(obj:GetDescendants()) do
        if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") then
            local n = v.Name:lower()
            if n:find("damage") or n:find("kill") or n:find("hit") or n:find("attack") or n:find("hurt") then
                pcall(function()
                    if v:IsA("RemoteEvent") then
                        v:FireServer(model, math.huge)
                        v:FireServer(hum,   math.huge)
                        v:FireServer(hum,   999999)
                        v:FireServer(model)
                    elseif v:IsA("RemoteFunction") then
                        v:InvokeServer(model, math.huge)
                        v:InvokeServer(hum,   math.huge)
                    end
                end)
            end
        end
    end
end

local function killNPC(model)
    if not model or not model.Parent then return end
    if isPlayer(model) then return end

    local hum = model:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return end

    -- 1) Desativa scripts de regen/heal antes de tudo
    for _, s in ipairs(model:GetDescendants()) do
        if s:IsA("Script") or s:IsA("LocalScript") then
            pcall(function() s.Disabled = true end)
        end
    end

    -- 2) Tenta forçar morte via Humanoid (client-sided games)
    pcall(function() hum.MaxHealth = 0 end)
    pcall(function() hum.Health    = 0 end)
    pcall(function() hum:TakeDamage(math.huge) end)
    pcall(function() hum:TakeDamage(999999) end)

    -- 3) Tenta via RemoteEvents do jogo (server-sided games como BL)
    tryRemotes(ReplicatedStorage, model, hum)
    tryRemotes(workspace, model, hum)

    -- 4) Procura remotes dentro do próprio modelo
    tryRemotes(model, model, hum)

    -- 5) Tenta BreakJoints como último recurso
    pcall(function() model:BreakJoints() end)
end

local function ikLoop()
    while ikActive do
        local myHRP = getHRP()
        if myHRP then
            local params = OverlapParams.new()
            params.FilterType = Enum.RaycastFilterType.Exclude
            local parts = workspace:GetPartBoundsInRadius(myHRP.Position, ikRange, params)
            local seen = {}
            for _, part in ipairs(parts) do
                local model = part:FindFirstAncestorOfClass("Model")
                if model and not seen[model] then
                    seen[model] = true
                    pcall(killNPC, model)
                end
            end
        end
        task.wait(0.08)
    end
end

-- ══════════════════════════════════════════
--  MOB AI BREAKER
--  Remove ou disabilita scripts de IA dos NPCs próximos
-- ══════════════════════════════════════════
local aiBreakActive = false
local function aiBreakLoop()
    while aiBreakActive do
        local myHRP = getHRP()
        if myHRP then
            for _, model in ipairs(workspace:GetDescendants()) do
