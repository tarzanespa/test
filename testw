local tVis = newTab("👁️ Visual")
local espConns = {}

newSection(tVis, "ESP")

newToggle(tVis, "ESP NPCs & Bosses", false, function(on)
    for _, c in ipairs(espConns) do c:Disconnect() end
    espConns = {}

    if on then
        local function applyESP(model)
            if not model:IsA("Model") then return end
            if not model:FindFirstChildOfClass("Humanoid") then return end
            if isPlayer(model) then return end
            local hrp = model:FindFirstChild("HumanoidRootPart")
            if not hrp or hrp:FindFirstChild("_ESP") then return end

            local hum = model:FindFirstChildOfClass("Humanoid")
            local boss = hum and hum.MaxHealth >= 500

            local bb = Instance.new("BillboardGui")
            bb.Name = "_ESP"
            bb.Size = UDim2.new(0, 120, 0, 30)
            bb.StudsOffset = Vector3.new(0, 3.5, 0)
            bb.AlwaysOnTop = true
            bb.Parent = hrp

            local tl = Instance.new("TextLabel")
            tl.Size = UDim2.new(1, 0, 1, 0)
            tl.BackgroundTransparency = 1
            tl.Text = (boss and "👑 " or "⚠ ") .. model.Name
            tl.TextSize = boss and 13 or 11
            tl.Font = Enum.Font.GothamBold
            tl.TextColor3 = boss and Color3.fromRGB(255,200,0) or Color3.fromRGB(255,70,70)
            tl.TextStrokeTransparency = 0
            tl.Parent = bb
        end

        for _, d in ipairs(workspace:GetDescendants()) do pcall(applyESP, d) end
        local c = workspace.DescendantAdded:Connect(function(d)
            task.wait(0.1)
            pcall(applyESP, d)
        end)
        table.insert(espConns, c)
        notify("ESP", "Ativo")
    else
        for _, d in ipairs(workspace:GetDescendants()) do
            local e = d:FindFirstChild("_ESP")
            if e then e:Destroy() end
        end
        notify("ESP", "Desativado")
    end
end)

