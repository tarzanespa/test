    local f = Instance.new("Frame")
    f.Size = UDim2.new(1, 0, 0, 50)
    f.BackgroundColor3 = ITEM_BG
    f.BorderSizePixel = 0
    f.ZIndex = 13
    f.Parent = tab.frame
    mkCorner(f, 6)

    local tl = Instance.new("TextLabel")
    tl.Size = UDim2.new(0.65, 0, 0, 22)
    tl.Position = UDim2.new(0, 10, 0, 5)
    tl.BackgroundTransparency = 1
    tl.Text = text
    tl.TextSize = 12
    tl.Font = Enum.Font.Gotham
    tl.TextColor3 = TEXT
    tl.TextXAlignment = Enum.TextXAlignment.Left
    tl.ZIndex = 14
    tl.Parent = f

    local vl = Instance.new("TextLabel")
    vl.Size = UDim2.new(0.35, -10, 0, 22)
    vl.Position = UDim2.new(0.65, 0, 0, 5)
    vl.BackgroundTransparency = 1
    vl.Text = tostring(val)
    vl.TextSize = 12
    vl.Font = Enum.Font.GothamBold
    vl.TextColor3 = ACCENT
    vl.TextXAlignment = Enum.TextXAlignment.Right
    vl.ZIndex = 14
    vl.Parent = f

    local bar = Instance.new("Frame")
    bar.Size = UDim2.new(1, -20, 0, 5)
    bar.Position = UDim2.new(0, 10, 1, -14)
    bar.BackgroundColor3 = Color3.fromRGB(40, 40, 60)
    bar.BorderSizePixel = 0
    bar.ZIndex = 14
    bar.Parent = f
    mkCorner(bar, 3)

    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((val-min)/(max-min), 0, 1, 0)
    fill.BackgroundColor3 = ACCENT
    fill.BorderSizePixel = 0
    fill.ZIndex = 15
    fill.Parent = bar
    mkCorner(fill, 3)

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 13, 0, 13)
    knob.AnchorPoint = Vector2.new(0.5, 0.5)
    knob.Position = UDim2.new((val-min)/(max-min), 0, 0.5, 0)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.BorderSizePixel = 0
    knob.ZIndex = 16
    knob.Parent = bar
    mkCorner(knob, 7)

    local dragging = false
    local function upd(x)
        local pct = math.clamp((x - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
        val = math.floor(min + pct * (max - min) + 0.5)
        fill.Size = UDim2.new(pct, 0, 1, 0)
        knob.Position = UDim2.new(pct, 0, 0.5, 0)
        vl.Text = tostring(val)
        if cb then pcall(cb, val) end
    end

    local hit = Instance.new("TextButton")
    hit.Size = UDim2.new(1, 0, 0, 24)
    hit.Position = UDim2.new(0, 0, 1, -18)
    hit.BackgroundTransparency = 1
    hit.Text = ""
    hit.ZIndex = 17
    hit.Parent = f
    hit.MouseButton1Down:Connect(function() dragging = true upd(Mouse.X) end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then upd(Mouse.X) end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)

    return { get = function() return val end }
end

