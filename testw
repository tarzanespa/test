newToggle(tPlr, "Player Aimbot (FOV + Smooth)", false, function(on)
    aimbotActive = on
    if on then
        aimbotConn = RunService.RenderStepped:Connect(function()
            local myHRP = getHRP()
            local cam   = workspace.CurrentCamera
            if not myHRP or not cam then return end
            local closest, closestDist = nil, aimbotFOV
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character then
                    local enemyHRP = p.Character:FindFirstChild("HumanoidRootPart")
                    local enemyHum = p.Character:FindFirstChildOfClass("Humanoid")
                    if enemyHRP and enemyHum and enemyHum.Health > 0 then
                        local screenPos, onScreen = cam:WorldToScreenPoint(enemyHRP.Position)
                        if onScreen then
                            local center = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)
                            local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                            if dist < closestDist then
                                closestDist = dist
                                closest = enemyHRP
                            end
                        end
                    end
                end
            end
            if closest then
                -- Smooth aim via CFrame lerp
                local targetCF = CFrame.new(cam.CFrame.Position, closest.Position)
                cam.CFrame = cam.CFrame:Lerp(targetCF, 0.15)
            end
        end)
        notify("Aimbot", "Ativo — FOV: " .. aimbotFOV)
    else
        if aimbotConn then aimbotConn:Disconnect() aimbotConn = nil end
        notify("Aimbot", "Desativado")
