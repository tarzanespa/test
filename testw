local parryActive   = false
local autoRollActive = false
local blockHolding  = false
local parryConn

newToggle(tParry, "Auto Parry (Reativo)", false, function(on)
    parryActive = on
    if on then
        -- Monitorar animações de ataque de inimigos próximos e disparar parry
        parryConn = RunService.Heartbeat:Connect(function()
            local myHRP = getHRP()
            if not myHRP then return end
            -- Detecta inimigos com animações de ataque ativas
            for _, model in ipairs(workspace:GetDescendants()) do
                if model:IsA("Model") and not isPlayer(model) then
                    local hum = model:FindFirstChildOfClass("Humanoid")
                    local animator = hum and hum:FindFirstChildOfClass("Animator")
                    if animator then
                        local tracks = animator:GetPlayingAnimationTracks()
                        for _, track in ipairs(tracks) do
                            local name = track.Name:lower()
                            if name:find("attack") or name:find("swing") or name:find("strike") then
                                -- Dispara parry via remote (adaptar ao jogo)
                                for _, v in ipairs(ReplicatedStorage:GetDescendants()) do
                                    if v:IsA("RemoteEvent") then
                                        local rn = v.Name:lower()
                                        if rn:find("parry") or rn:find("block") then
                                            pcall(function() v:FireServer() end)
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end)
        notify("Auto Parry", "Ativo")
    else
        if parryConn then parryConn:Disconnect() parryConn = nil end
        notify("Auto Parry", "Desativado")
    end
end)

