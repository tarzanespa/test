local function switchTab(tab)
    if ActiveTab == tab then return end
    for _, t in ipairs(Tabs) do
        t.frame.Visible = false
        tw(t.btn, {BackgroundTransparency = 1, TextColor3 = MUTED}, 0.15)
    end
    ActiveTab = tab
    tab.frame.Visible = true
    tw(tab.btn, {BackgroundTransparency = 0.8, TextColor3 = TEXT}, 0.15)
end

