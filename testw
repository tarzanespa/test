local function addToggle(tab, text, default, callback)
    local state = default or false

    local f = Instance.new("Frame")
    f.Size = UDim2.new(1,0,0,40)
    f.BackgroundColor3 = Color3.fromRGB(28,28,42)
    f.BorderSizePixel = 0
    f.ZIndex = 13
    f.Parent = tab.frame
    corner(f, 6)

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1,-60,1,0)
    lbl.Position = UDim2.new(0,12,0,0)
    lbl.BackgroundTransparency = 1
    lbl.Text = text
    lbl.TextSize = 13
    lbl.Font = Enum.Font.Gotham
    lbl.TextColor3 = CONFIG.TextColor
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.ZIndex = 14
    lbl.Parent = f

    local track = Instance.new("Frame")
    track.Size = UDim2.new(0,40,0,20)
    track.Position = UDim2.new(1,-52,0.5,-10)
    track.BackgroundColor3 = Color3.fromRGB(50,50,70)
    track.BorderSizePixel = 0
    track.ZIndex = 14
    track.Parent = f
    corner(track, 10)

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0,14,0,14)
    knob.Position = UDim2.new(0,3,0.5,-7)
    knob.BackgroundColor3 = Color3.fromRGB(160,160,190)
    knob.BorderSizePixel = 0
    knob.ZIndex = 15
    knob.Parent = track
    corner(knob, 7)

    local function refresh()
        if state then
            tween(track, {BackgroundColor3=CONFIG.AccentColor}, 0.18)
            tween(knob, {Position=UDim2.new(1,-17,0.5,-7), BackgroundColor3=Color3.fromRGB(255,255,255)}, 0.18)
        else
            tween(track, {BackgroundColor3=Color3.fromRGB(50,50,70)}, 0.18)
            tween(knob, {Position=UDim2.new(0,3,0.5,-7), BackgroundColor3=Color3.fromRGB(160,160,190)}, 0.18)
        end
        if callback then callback(state) end
    end
    refresh()

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1,0,1,0)
    btn.BackgroundTransparency = 1
    btn.Text = ""
    btn.ZIndex = 16
    btn.Parent = f
    btn.MouseButton1Click:Connect(function()
        state = not state
        refresh()
    end)

    return { get=function() return state end, set=function(v) state=v refresh() end }
end

local function addSlider(tab, text, min, max, default, callback)
    min, max = min or 0, max or 100
    local value = math.clamp(default or min, min, max)

    local f = Instance.new("Frame")
    f.Size = UDim2.new(1,0,0,54)
    f.BackgroundColor3 = Color3.fromRGB(28,28,42)
    f.BorderSizePixel = 0
    f.ZIndex = 13
    f.Parent = tab.frame
    corner(f, 6)

    local tl = Instance.new("TextLabel")
    tl.Size = UDim2.new(0.7,0,0,24)
    tl.Position = UDim2.new(0,12,0,6)
    tl.BackgroundTransparency = 1
    tl.Text = text
    tl.TextSize = 13
    tl.Font = Enum.Font.Gotham
    tl.TextColor3 = CONFIG.TextColor
    tl.TextXAlignment = Enum.TextXAlignment.Left
    tl.ZIndex = 14
    tl.Parent = f

    local vl = Instance.new("TextLabel")
    vl.Size = UDim2.new(0.3,-12,0,24)
    vl.Position = UDim2.new(0.7,0,0,6)
    vl.BackgroundTransparency = 1
    vl.Text = tostring(value)
    vl.TextSize = 13
    vl.Font = Enum.Font.GothamBold
    vl.TextColor3 = CONFIG.AccentColor
    vl.TextXAlignment = Enum.TextXAlignment.Right
    vl.ZIndex = 14
    vl.Parent = f

    local track = Instance.new("Frame")
    track.Size = UDim2.new(1,-24,0,6)
    track.Position = UDim2.new(0,12,1,-16)
    track.BackgroundColor3 = Color3.fromRGB(45,45,65)
    track.BorderSizePixel = 0
    track.ZIndex = 14
    track.Parent = f
    corner(track, 3)

    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((value-min)/(max-min),0,1,0)
    fill.BackgroundColor3 = CONFIG.AccentColor
    fill.BorderSizePixel = 0
    fill.ZIndex = 15
    fill.Parent = track
    corner(fill, 3)

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0,14,0,14)
    knob.AnchorPoint = Vector2.new(0.5,0.5)
    knob.Position = UDim2.new((value-min)/(max-min),0,0.5,0)
    knob.BackgroundColor3 = Color3.fromRGB(255,255,255)
    knob.BorderSizePixel = 0
    knob.ZIndex = 16
    knob.Parent = track
    corner(knob, 7)

    local dragging = false
    local function updateSlider(x)
        local pct = math.clamp((x - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        value = math.floor(min + pct*(max-min) + 0.5)
        fill.Size = UDim2.new(pct,0,1,0)
        knob.Position = UDim2.new(pct,0,0.5,0)
        vl.Text = tostring(value)
        if callback then callback(value) end
    end

    local hitbox = Instance.new("TextButton")
    hitbox.Size = UDim2.new(1,0,0,26)
    hitbox.Position = UDim2.new(0,0,1,-20)
    hitbox.BackgroundTransparency = 1
    hitbox.Text = ""
    hitbox.ZIndex = 17
    hitbox.Parent = f
    hitbox.MouseButton1Down:Connect(function() dragging=true updateSlider(Mouse.X) end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType==Enum.UserInputType.MouseMovement then updateSlider(Mouse.X) end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end
    end)

    return {
        get = function() return value end,
        set = function(v)
            value = math.clamp(v,min,max)
            local pct = (value-min)/(max-min)
            fill.Size = UDim2.new(pct,0,1,0)
            knob.Position = UDim2.new(pct,0,0.5,0)
            vl.Text = tostring(value)
        end,
    }
end

