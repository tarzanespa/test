local function switchTab(tab)
    if ActiveTab == tab then return end
    for _, t in ipairs(Tabs) do
        t.frame.Visible = false
        tw(t.btn, {BackgroundTransparency = 1, TextColor3 = MUTED}, 0.15)
    end
    ActiveTab = tab
    tab.frame.Visible = true
    tw(tab.btn, {BackgroundTransparency = 0.8, TextColor3 = TEXT}, 0.15)
end

local function newTab(name)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 0, 32)
    btn.BackgroundColor3 = ACCENT
    btn.BackgroundTransparency = 1
    btn.Text = name
    btn.TextSize = 11
    btn.Font = Enum.Font.GothamSemibold
    btn.TextColor3 = MUTED
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.ZIndex = 12
    btn.Parent = Sidebar
    mkCorner(btn, 5)

    local bp = Instance.new("UIPadding")
    bp.PaddingLeft = UDim.new(0, 9)
    bp.Parent = btn

    local frame = Instance.new("ScrollingFrame")
    frame.Size = UDim2.new(1, 0, 1, 0)
    frame.BackgroundTransparency = 1
    frame.BorderSizePixel = 0
    frame.ZIndex = 12
    frame.Visible = false
    frame.ScrollBarThickness = 3
    frame.ScrollBarImageColor3 = ACCENT
    frame.CanvasSize = UDim2.new(0, 0, 0, 0)
    frame.AutomaticCanvasSize = Enum.AutomaticSize.Y
    frame.Parent = Content

    local ll = Instance.new("UIListLayout")
    ll.Padding = UDim.new(0, 5)
    ll.Parent = frame

    local pp = Instance.new("UIPadding")
    pp.PaddingTop    = UDim.new(0, 8)
    pp.PaddingLeft   = UDim.new(0, 8)
    pp.PaddingRight  = UDim.new(0, 8)
    pp.PaddingBottom = UDim.new(0, 8)
    pp.Parent = frame

    local t = {btn = btn, frame = frame}
    table.insert(Tabs, t)
    btn.MouseButton1Click:Connect(function() switchTab(t) end)
    if #Tabs == 1 then switchTab(t) end
    return t
end

