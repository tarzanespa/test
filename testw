local function newToggle(tab, text, default, cb)
    local state = default or false

    local f = Instance.new("Frame")
    f.Size = UDim2.new(1, 0, 0, 38)
    f.BackgroundColor3 = ITEM_BG
    f.BorderSizePixel = 0
    f.ZIndex = 13
    f.Parent = tab.frame
    mkCorner(f, 6)

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -58, 1, 0)
    lbl.Position = UDim2.new(0, 10, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = text
    lbl.TextSize = 12
    lbl.Font = Enum.Font.Gotham
    lbl.TextColor3 = TEXT
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.ZIndex = 14
    lbl.Parent = f

    local track = Instance.new("Frame")
    track.Size = UDim2.new(0, 38, 0, 18)
    track.Position = UDim2.new(1, -48, 0.5, -9)
    track.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
    track.BorderSizePixel = 0
    track.ZIndex = 14
    track.Parent = f
    mkCorner(track, 9)

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 12, 0, 12)
    knob.Position = UDim2.new(0, 3, 0.5, -6)
    knob.BackgroundColor3 = Color3.fromRGB(150, 150, 180)
    knob.BorderSizePixel = 0
    knob.ZIndex = 15
    knob.Parent = track
    mkCorner(knob, 6)

    local function refresh()
        if state then
            tw(track, {BackgroundColor3 = ACCENT}, 0.15)
            tw(knob, {Position = UDim2.new(1, -15, 0.5, -6), BackgroundColor3 = Color3.fromRGB(255,255,255)}, 0.15)
        else
            tw(track, {BackgroundColor3 = Color3.fromRGB(50,50,70)}, 0.15)
            tw(knob, {Position = UDim2.new(0, 3, 0.5, -6), BackgroundColor3 = Color3.fromRGB(150,150,180)}, 0.15)
        end
        if cb then pcall(cb, state) end
    end
    refresh()

    local hit = Instance.new("TextButton")
    hit.Size = UDim2.new(1, 0, 1, 0)
    hit.BackgroundTransparency = 1
    hit.Text = ""
    hit.ZIndex = 16
    hit.Parent = f
    hit.MouseButton1Click:Connect(function()
        state = not state
        refresh()
    end)

    return {
        get = function() return state end,
        set = function(v) state = v refresh() end,
    }
end

local function newSlider(tab, text, min, max, default, cb)
