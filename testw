    ipad.Parent = inner

    local t1 = Instance.new("TextLabel")
    t1.Size = UDim2.new(1,0,0,16)
    t1.BackgroundTransparency = 1
    t1.Text = title
    t1.TextSize = 12
    t1.Font = Enum.Font.GothamBold
    t1.TextColor3 = CONFIG.TextColor
    t1.TextXAlignment = Enum.TextXAlignment.Left
    t1.ZIndex = 53
    t1.Parent = inner

    local t2 = Instance.new("TextLabel")
    t2.Size = UDim2.new(1,0,0,14)
    t2.Position = UDim2.new(0,0,0,18)
    t2.BackgroundTransparency = 1
    t2.Text = msg
    t2.TextSize = 11
    t2.Font = Enum.Font.Gotham
    t2.TextColor3 = CONFIG.MutedColor
    t2.TextXAlignment = Enum.TextXAlignment.Left
    t2.ZIndex = 53
    t2.Parent = inner

    tween(nf, {BackgroundTransparency=0}, 0.2)
    task.delay(duration, function()
        tween(nf, {BackgroundTransparency=1}, 0.3)
        task.wait(0.35)
        nf:Destroy()
    end)
